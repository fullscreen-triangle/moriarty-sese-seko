# =====================================================================
#  NPC Persuasion Demo — environment configuration
#  Copy this file to `.env.local` and fill in the values you need.
# =====================================================================

# Which LLM backend judges the user's argument.
#   ollama = a local Ollama server (no API cost, runs offline)
#   hf     = Hugging Face Inference API (needs a token, works when deployed)
LLM_PROVIDER=ollama

# ---- Ollama (LLM_PROVIDER=ollama) -----------------------------------
# Base URL of your local Ollama server.
OLLAMA_URL=http://localhost:11434
# Model to use. Pull it first, e.g. `ollama pull llama3.2`.
OLLAMA_MODEL=llama3.2

# ---- Hugging Face (LLM_PROVIDER=hf) ---------------------------------
# Create a token at https://huggingface.co/settings/tokens
# Put your real token in .env.local (gitignored), NOT here.
HF_TOKEN=
# Any chat model served by the HF router (https://router.huggingface.co).
# Note: not every instruct model is exposed as a chat model — pick one that is.
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces \textbf  {Catalytic Drift and Forced Inquiry: Rumour Without an Author, a Question Without Intent.} (\textbf  {A})~Surviving fraction $\DOTSB \prod@ \slimits@ _i g_i$ on the linear $y$-axis versus number of relays $n$ on the linear $x$-axis ($1$ to $14$), for three per-relay gains $g_i\in \{0.6,0.75,0.9\}$ (steel-blue, sea-green, amber). Each curve decays geometrically, the empirical content of \Cref  {thm:drift}: a relayed account drifts multiplicatively along a chain. (\textbf  {B})~Histogram of account drift $1-\DOTSB \prod@ \slimits@ _i g_i$ on the linear $x$-axis over $400$ random relay chains, counts on the linear $y$-axis (violet). Drift accumulates across the population, the empirical content of \Cref  {cor:rumour}: rumour is composed drift, authored by no relay. (\textbf  {C})~Residual gap $D$ on the linear $y$-axis versus exchange turn on the linear $x$-axis ($0$ to $30$) (steel-blue, positive region shaded amber), each forced act marked (crimson) and the closing line $D=0$ marked (sea-green, dashed). A further act is committed exactly while $D>0$ and the exchange closes only at $D=0$, the empirical content of \Cref  {thm:forcedact}: inquiry is forced by the gap. (\textbf  {D})~Three-dimensional drift surface $1-\DOTSB \prod@ \slimits@ _i g_i$ over number of relays $n$ ($x$-axis, $1$ to $14$) and per-relay gain $g$ ($y$-axis, $0.4$ to $0.98$) (viridis colourmap), viewing angle elevation $26^{\circ }$ azimuth $-60^{\circ }$. Drift grows with chain length and with per-relay reshaping, the geometric picture of catalytic drift.}}{12}{figure.caption.5}\protected@file@percent }
\newlabel{fig:mechanics-4}{{4}{12}{\textbf {Catalytic Drift and Forced Inquiry: Rumour Without an Author, a Question Without Intent.} (\textbf {A})~Surviving fraction $\prod _i g_i$ on the linear $y$-axis versus number of relays $n$ on the linear $x$-axis ($1$ to $14$), for three per-relay gains $g_i\in \{0.6,0.75,0.9\}$ (steel-blue, sea-green, amber). Each curve decays geometrically, the empirical content of \Cref {thm:drift}: a relayed account drifts multiplicatively along a chain. (\textbf {B})~Histogram of account drift $1-\prod _i g_i$ on the linear $x$-axis over $400$ random relay chains, counts on the linear $y$-axis (violet). Drift accumulates across the population, the empirical content of \Cref {cor:rumour}: rumour is composed drift, authored by no relay. (\textbf {C})~Residual gap $D$ on the linear $y$-axis versus exchange turn on the linear $x$-axis ($0$ to $30$) (steel-blue, positive region shaded amber), each forced act marked (crimson) and the closing line $D=0$ marked (sea-green, dashed). A further act is committed exactly while $D>0$ and the exchange closes only at $D=0$, the empirical content of \Cref {thm:forcedact}: inquiry is forced by the gap. (\textbf {D})~Three-dimensional drift surface $1-\prod _i g_i$ over number of relays $n$ ($x$-axis, $1$ to $14$) and per-relay gain $g$ ($y$-axis, $0.4$ to $0.98$) (viridis colourmap), viewing angle elevation $26^{\circ }$ azimuth $-60^{\circ }$. Drift grows with chain length and with per-relay reshaping, the geometric picture of catalytic drift}{figure.caption.5}{}}
\newlabel{fig:mechanics-4@cref}{{[figure][4][]4}{[1][11][]12}{}{}{}}

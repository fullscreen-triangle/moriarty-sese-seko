\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textbf  {The Floor and Recall-Is-Search: No Item Is Individuated for Free, and No Report Is Fetched.} (\textbf  {A})~Separation cost $\sigma (v)$ on the linear $y$-axis versus world size in items on the linear $x$-axis ($3$ to $9$), every item of $80$ random worlds (steel-blue), with the floor line marked (crimson). Every separation cost, computed as an exact minimum cut, sits on or above the floor: the empirical content of \Cref  {thm:floorforced}, that identifying an item carries an irreducible residual $\sigma (v)\ge \beta >0$. (\textbf  {B})~Histogram of the normalised separation cost $\sigma (v)/\beta $ on the linear $x$-axis with the unit line marked (crimson), counts on the linear $y$-axis (sea-green). The support begins at $1$ and the smallest observed value is $1.092$---the floor is close to tight, so the residual the whole paper turns on is real and small. (\textbf  {C})~Report produced (none / yes) on the $y$-axis versus committed acts in the search on the linear $x$-axis ($0$ to $12$) (steel-blue step, positive region shaded sea-green), with the zero-act case ringed (crimson). A report appears only after at least one committed act, the empirical content of \Cref  {thm:recsearch}: recalling is searching and a zero-act fetch returns nothing. (\textbf  {D})~Three-dimensional realised-floor surface over world size in items ($x$-axis, $3$ to $9$) and graph density ($y$-axis, $0.2$ to $0.9$) (viridis colourmap), viewing angle elevation $24^{\circ }$ azimuth $-58^{\circ }$. The realised floor stays strictly positive across the grid: no configuration individuates any item for free.}}{5}{figure.caption.2}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:mechanics-1}{{1}{5}{\textbf {The Floor and Recall-Is-Search: No Item Is Individuated for Free, and No Report Is Fetched.} (\textbf {A})~Separation cost $\sigma (v)$ on the linear $y$-axis versus world size in items on the linear $x$-axis ($3$ to $9$), every item of $80$ random worlds (steel-blue), with the floor line marked (crimson). Every separation cost, computed as an exact minimum cut, sits on or above the floor: the empirical content of \Cref {thm:floorforced}, that identifying an item carries an irreducible residual $\sigma (v)\ge \flo >0$. (\textbf {B})~Histogram of the normalised separation cost $\sigma (v)/\flo $ on the linear $x$-axis with the unit line marked (crimson), counts on the linear $y$-axis (sea-green). The support begins at $1$ and the smallest observed value is $1.092$---the floor is close to tight, so the residual the whole paper turns on is real and small. (\textbf {C})~Report produced (none / yes) on the $y$-axis versus committed acts in the search on the linear $x$-axis ($0$ to $12$) (steel-blue step, positive region shaded sea-green), with the zero-act case ringed (crimson). A report appears only after at least one committed act, the empirical content of \Cref {thm:recsearch}: recalling is searching and a zero-act fetch returns nothing. (\textbf {D})~Three-dimensional realised-floor surface over world size in items ($x$-axis, $3$ to $9$) and graph density ($y$-axis, $0.2$ to $0.9$) (viridis colourmap), viewing angle elevation $24^{\circ }$ azimuth $-58^{\circ }$. The realised floor stays strictly positive across the grid: no configuration individuates any item for free}{figure.caption.2}{}}
\newlabel{fig:mechanics-1@cref}{{[figure][1][]1}{[1][4][]5}{}{}{}}

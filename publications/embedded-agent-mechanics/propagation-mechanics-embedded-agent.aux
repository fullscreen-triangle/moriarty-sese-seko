\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces \textbf  {Receiver-Relative Divergence and Falsity as a Relation: The Same Event, Two Correct Accounts.} (\textbf  {A})~Dense-agent separation cost $\sigma (v)$ on the linear $y$-axis versus sparse-agent $\sigma (v)$ on the linear $x$-axis for the same event, $150$ agent pairs (steel-blue), with the identity diagonal marked (crimson, dashed). The points sit off the diagonal: the same event registers a different---yet, as an exact min-cut, correct---resting cut in each agent, the empirical content of \Cref  {thm:receiverrel}. (\textbf  {B})~Histogram of the registration difference across agents on the linear $x$-axis with zero marked (crimson), counts on the linear $y$-axis (amber). The mass sits away from zero: divergence is broad and is not error in either agent (\Cref  {cor:divergence}). (\textbf  {C})~Agreement matrix of resting-cut sides, account agent ($y$-axis) against elected standard agent ($x$-axis), eight agents, cells equal (green) or unequal (pale). Whether two accounts ``agree'' depends on which is taken as standard, the empirical content of \Cref  {thm:falsityrelation}: falsity is a relation on a pair, not a state of the producer. (\textbf  {D})~Three-dimensional surface of an event's separation cost over two agents' densities (both density axes $0.2$ to $0.9$) (viridis colourmap), viewing angle elevation $24^{\circ }$ azimuth $-58^{\circ }$. The cost varies smoothly with the receiving graph: there is no privileged shared value of which the registrations are approximations.}}{9}{figure.caption.4}\protected@file@percent }
\newlabel{fig:mechanics-3}{{3}{9}{\textbf {Receiver-Relative Divergence and Falsity as a Relation: The Same Event, Two Correct Accounts.} (\textbf {A})~Dense-agent separation cost $\sigma (v)$ on the linear $y$-axis versus sparse-agent $\sigma (v)$ on the linear $x$-axis for the same event, $150$ agent pairs (steel-blue), with the identity diagonal marked (crimson, dashed). The points sit off the diagonal: the same event registers a different---yet, as an exact min-cut, correct---resting cut in each agent, the empirical content of \Cref {thm:receiverrel}. (\textbf {B})~Histogram of the registration difference across agents on the linear $x$-axis with zero marked (crimson), counts on the linear $y$-axis (amber). The mass sits away from zero: divergence is broad and is not error in either agent (\Cref {cor:divergence}). (\textbf {C})~Agreement matrix of resting-cut sides, account agent ($y$-axis) against elected standard agent ($x$-axis), eight agents, cells equal (green) or unequal (pale). Whether two accounts ``agree'' depends on which is taken as standard, the empirical content of \Cref {thm:falsityrelation}: falsity is a relation on a pair, not a state of the producer. (\textbf {D})~Three-dimensional surface of an event's separation cost over two agents' densities (both density axes $0.2$ to $0.9$) (viridis colourmap), viewing angle elevation $24^{\circ }$ azimuth $-58^{\circ }$. The cost varies smoothly with the receiving graph: there is no privileged shared value of which the registrations are approximations}{figure.caption.4}{}}
\newlabel{fig:mechanics-3@cref}{{[figure][3][]3}{[1][8][]9}{}{}{}}
